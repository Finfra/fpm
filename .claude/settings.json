{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(/.claude/skills/cdf/**)",
      "Edit(/.claude/skills/fapp/**)",
      "Edit(/.claude/skills/issue/**)",
      "Edit(~/.claude/skills/md-rule-apply/**)",
      "Edit(/.claude/skills/pm/**)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/nowage/_git/__all/social",
      "/Users/nowage/_git/__all/finfraHome/.claude/commands"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; [[ \"$f\" == *Projects.md ]] && python3 ~/.bin/update-iterm-bg; } 2>/dev/null || true",
            "statusMessage": "iterm-bg alias \uc5c5\ub370\uc774\ud2b8 \uc911..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}